# Striven API credentials (READ-ONLY — never write back to Striven)
STRIVEN_CLIENT_ID=your_client_id_here
STRIVEN_CLIENT_SECRET=your_client_secret_here

# Supabase credentials (our controlled data layer)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here

# OpenAI — used for knowledge base embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Notion — used by sync_knowledge_base.py to pull pages into the vector KB
NOTION_API_KEY=secret_...
